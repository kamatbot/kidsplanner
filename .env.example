# Copy to .env (or set in your host's env panel). Never commit real secrets.
SESSION_SECRET=change-me-to-a-long-random-string
PORT=4000

# ---- Data encryption at rest ----
# Encrypts the whole user datastore (db.json) on disk with AES-256-GCM —
# covers chat messages + kids' schedule/activity data. Generate one with:
#   node scripts/gen-encryption-key.js
# (32 bytes; accepts 64 hex chars or base64.) Then set it here / in the host env
# panel and restart. The file transparently upgrades to encrypted on the next write.
#
# BACK THIS KEY UP SOMEWHERE SAFE (a password manager / secrets vault). If it is
#   LOST the encrypted db.json CANNOT be recovered; if you CHANGE it the existing
#   data can no longer be decrypted. Leaving it blank keeps data in plaintext.
#   Record the backup location in APP-BRIEF.md before first production deploy.
DATA_ENCRYPTION_KEY=

# ---- Passkeys / WebAuthn ----
# By default the app derives these from the incoming request (works on
# localhost and on Hostinger behind its TLS proxy). Set them explicitly in
# production for robustness — especially if you sit behind a CDN/proxy.
#   RP_ID:     the registrable domain, no scheme/port  (e.g. fametc.com)
#   RP_ORIGIN: the full origin, comma-separated list allowed
#              (e.g. https://fametc.com,https://www.fametc.com)
#   RP_NAME:   shown in the OS passkey prompt
# IMPORTANT: passkeys require HTTPS in production (localhost is exempt).
RP_ID=
RP_ORIGIN=
RP_NAME=Fam ETC

# ---- iOS app (Fam ETC) Associated Domains ----
# Comma-separated "<TEAMID>.<bundleId>" entries served in the apple-app-site-
# association file so the native iOS app shares this site's passkeys. Must match
# the SHIPPED bundle id (B4F73U5RGR.com.fametc.app) or native passkeys fail with
# "Application … is not associated with domain". server.js also hardcodes the
# shipped id as a safety net. Set this in the Hostinger Node env panel and redeploy.
IOS_APP_IDS=B4F73U5RGR.com.fametc.app

# Persistent data directory — MUST point OUTSIDE the deploy folder so a new
# build upload never overwrites user data (db.json). Use an absolute path on
# a writable volume. If unset, defaults to ~/.fametc-data.
# Example (Hostinger): /home/youruser/fametc-data
FAM_DATA_DIR=

# ---- iOS native client identification (optional but recommended) ----
# Shared secret the native app presents (header on native calls, embedded in
# the WKWebView User-Agent) so the server can reliably tell native/web-shell
# traffic apart — used for the free-iOS-at-launch billing gate. Generate any
# long random string and bake the SAME value into the iOS build.
IOS_CLIENT_SECRET=

# ---- Stripe billing (env-gated: leave any of the three blank to keep the
# app fully open, e.g. in local dev) ----
# Web only — iOS ships free at launch, StoreKit 2 IAP later (never Stripe in-app).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_LIFETIME_PRICE_ID=
BILLING_PORTAL_RETURN_URL=
TRIAL_DAYS=30
ANNUAL_PRICE_LABEL=
LIFETIME_PRICE_LABEL=

# ---- Analytics dashboard ----
ANALYTICS_TOKEN=

# ---- Rate limiting overrides (optional) ----
RL_API_MAX=
RL_AUTH_MAX=
RL_SIGNUP_MAX=
RL_MAX_KEYS=

# ---- Canonical host (SEO redirects) ----
CANONICAL_HOST=https://www.fametc.com

# ---- APNs push (net-new; portable apns-sender core — see lib/apns-sender/README.md) ----
# ALL app identity for push comes from these vars; the sender core itself has
# zero Fam ETC references and is designed to be copied into other projects
# (RetireOdds, mytharva) unchanged. Leave blank to run with push disabled —
# lib/fam-notifications.js no-ops safely when unconfigured.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.fametc.app
APNS_KEY_PATH=
# APNS_KEY=            # alternative to APNS_KEY_PATH: paste the .p8 contents directly (e.g. from a secret manager)
APNS_PRODUCTION=false

# ---- Web Push (net-new; portable webpush-sender core — see lib/webpush-sender/README.md) ----
# Browser push (Chrome/FCM, Firefox, Edge, and Safari on installed PWAs for
# iOS 16.4+/macOS). Zero Fam ETC references live in the sender core itself —
# designed to be copied into other projects (RetireOdds, mytharva) unchanged.
# Leave blank to run with web push disabled — lib/fam-notifications.js
# no-ops safely when unconfigured. Generate a key pair with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY is not secret (the browser client uses it to subscribe);
# VAPID_PRIVATE_KEY IS secret — keep it out of any client-facing code/response.
VAPID_PUBLIC_KEY=PLACEHOLDER_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=PLACEHOLDER_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:hello@example.com

# Giphy API key for chat GIF search (server-side proxy). Get one free at developers.giphy.com.
GIPHY_API_KEY=
