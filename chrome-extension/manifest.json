{
  "manifest_version": 3,
  "name": "Fam ETC School Import",
  "version": "0.2.0",
  "description": "Auto-syncs your child's Moodle homework and timetable into Fam ETC using your already-logged-in Moodle session.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fam ETC School Import"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://bangkok.learn.nae.school/*"],
      "js": ["parse.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["scripting", "tabs", "activeTab", "storage"],
  "host_permissions": [
    "https://bangkok.learn.nae.school/*",
    "https://www.fametc.com/*",
    "https://fametc.com/*"
  ]
}
